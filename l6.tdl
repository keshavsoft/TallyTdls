[Collection: KeshavLedgers]
Type    : Ledger
Fetch   : Name, Parent

Compute : GSTRegistrationType : $GSTRegistrationType
Compute : PartyGSTIN          : $PartyGSTIN
Compute : GUID                : $GUID
Compute : CurrencyName        : $CurrencyName
Compute : StateName           : $StateName

Format  : JSON

[Collection: KeshavStockItems]
Type : StockItem
Fetch : Name, Parent, Category, BaseUnits, GSTApplicable, GSTTypeOfSupply, GSTDetails
Format : JSON